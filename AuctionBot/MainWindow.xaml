<Window x:Class="AuctionBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auction Bot"
        Width="1200"
        Height="750"
        MinWidth="1200"
        MinHeight="750"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Левая колонка -->
            <ColumnDefinition Width="260"/>
            <!-- Правая основная часть -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT: ЦЕНЫ ================= -->
        <Border Grid.Column="0"
        Background="#2B2B2B"
        CornerRadius="6"
        Padding="10"
        Margin="0,0,10,0">

            <StackPanel>
                <TextBlock Text="ЦЕНЫ"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

                <UniformGrid Rows="9" Margin="0,5,0,0">

                    <!-- 9 слотов под цены -->
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#1E1E1E" Margin="0,3" Height="45" CornerRadius="4">
                        <TextBlock Text="---" Foreground="Gray" FontSize="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ================= RIGHT ================= -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- ===== STATUS ===== -->
            <Border Grid.Row="0"
                Background="#3A3A3A"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,10">
                <TextBlock x:Name="StatusTextBlock"
                   Text=""
                   Foreground="White"
                   FontSize="18"
                   VerticalAlignment="Center"/>
            </Border>

            <!-- ===== INPUTS ===== -->
            <Border Grid.Row="1"
            Background="#2B2B2B"
            CornerRadius="6"
            Padding="10"
            Margin="0,0,0,10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <!-- Название товара -->
                    <TextBox x:Name="ProductNameTextBox"
                 Grid.Column="0"
                 Background="#1E1E1E"
                 Foreground="White"
                 FontSize="16"
                 Height="35"
                 Margin="0,2,10,2"/>

                    <!-- Цена -->
                    <TextBox x:Name="PriceTextBox"
                 Grid.Column="1"
                 Background="#1E1E1E"
                 Foreground="White"
                 FontSize="16"
                 Height="35"
                 Margin="0,2,10,2"/>

                    <!-- ГОТОВО -->
                    <Button Grid.Column="2"
                Content="ГОТОВО"
                FontSize="16"
                Background="#8B0000"
                Foreground="White"
                Height="35"
                Margin="0,2,0,2"/>
                </Grid>
            </Border>

            <!-- ===== COORDINATES ===== -->
            <Border Grid.Row="2"
                    Background="#2B2B2B"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,0,0,10">

                <UniformGrid Columns="2" Rows="3" Margin="5">

                    <Border Background="#3A3A3A"
                    CornerRadius="6"
                    Height="70"
                    Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Левая тёмная часть -->
                                <ColumnDefinition Width="70"/>
                                <!-- Правая основная -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВЫЙ КВАДРАТ -->
                            <Border Grid.Column="0"
                            Background="#2A2A2A"
                            CornerRadius="6,0,0,6"
                            Padding="5">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- X,Y -->
                                    <TextBlock Text="X, Y"
                                    Foreground="Gray"
                                    FontSize="12"
                                    HorizontalAlignment="Center"/>

                                    <!-- Координаты -->
                                    <Border Grid.Row="1"
                                    Background="#3A3A3A"
                                    CornerRadius="4"
                                    Margin="5,6,5,0"
                                    VerticalAlignment="Center">

                                        <TextBlock x:Name="SearchXY"
                                           Text="0 , 0"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ПРАВАЯ ЧАСТЬ -->
                            <Grid Grid.Column="1"
                            Margin="8,6">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Название -->
                                <Border Background="#2F2F2F"
                                    CornerRadius="4"
                                    Padding="4"
                                    Margin="0,0,0,6">

                                    <TextBlock Text="''Поиск''"
                                    Foreground="White"
                                    FontSize="13"
                                    HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Кнопка -->
                                <Button Name="Search" 
                                Grid.Row="1"
                                Content="НАСТРОИТЬ КООРДИНАТЫ"
                                Background="#8B0000"
                                Foreground="White"
                                FontSize="12"
                                Height="28"
                                Click="Search_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Background="#3A3A3A"
                    CornerRadius="6"
                    Height="70"
                    Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Левая тёмная часть -->
                                <ColumnDefinition Width="70"/>
                                <!-- Правая основная -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВЫЙ КВАДРАТ -->
                            <Border Grid.Column="0"
                            Background="#2A2A2A"
                            CornerRadius="6,0,0,6"
                            Padding="5">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- X,Y -->
                                    <TextBlock Text="X, Y"
                                    Foreground="Gray"
                                    FontSize="12"
                                    HorizontalAlignment="Center"/>

                                    <!-- Координаты -->
                                    <Border Grid.Row="1"
                                    Background="#3A3A3A"
                                    CornerRadius="4"
                                    Margin="5,6,5,0"
                                    VerticalAlignment="Center">

                                        <TextBlock x:Name="RedemptionPricesXY"
                                           Text="0 , 0"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ПРАВАЯ ЧАСТЬ -->
                            <Grid Grid.Column="1"
                            Margin="8,6">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Название -->
                                <Border Background="#2F2F2F"
                                CornerRadius="4"
                                Padding="4"
                                Margin="0,0,0,6">

                                    <TextBlock Text="''Цены выкупа''"
                                    Foreground="White"
                                    FontSize="13"
                                    HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Кнопка -->
                                <Button Name="RedemptionPrices"
                                Grid.Row="1"
                                Content="НАСТРОИТЬ КООРДИНАТЫ"
                                Background="#8B0000"
                                Foreground="White"
                                FontSize="12"
                                Height="28"
                                Click="RedemptionPrices_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Background="#3A3A3A"
                    CornerRadius="6"
                    Height="70"
                    Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Левая тёмная часть -->
                                <ColumnDefinition Width="70"/>
                                <!-- Правая основная -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВЫЙ КВАДРАТ -->
                            <Border Grid.Column="0"
                            Background="#2A2A2A"
                            CornerRadius="6,0,0,6"
                            Padding="5">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- X,Y -->
                                    <TextBlock Text="X, Y"
                                    Foreground="Gray"
                                    FontSize="12"
                                    HorizontalAlignment="Center"/>

                                    <!-- Координаты -->
                                    <Border Grid.Row="1"
                                    Background="#3A3A3A"
                                    CornerRadius="4"
                                    Margin="5,6,5,0"
                                    VerticalAlignment="Center">

                                        <TextBlock x:Name="DownArrowXY"
                                           Text="0 , 0"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ПРАВАЯ ЧАСТЬ -->
                            <Grid Grid.Column="1"
                            Margin="8,6">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Название -->
                                <Border Background="#2F2F2F"
                                CornerRadius="4"
                                Padding="4"
                                Margin="0,0,0,6">

                                    <TextBlock Text="''Стрелка вниз''"
                                    Foreground="White"
                                    FontSize="13"
                                    HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Кнопка -->
                                <Button Name="DownArrow"
                                Grid.Row="1"
                                Content="НАСТРОИТЬ КООРДИНАТЫ"
                                Background="#8B0000"
                                Foreground="White"
                                FontSize="12"
                                Height="28"
                                Click="DownArrow_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Background="#3A3A3A"
                    CornerRadius="6"
                    Height="70"
                    Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Левая тёмная часть -->
                                <ColumnDefinition Width="70"/>
                                <!-- Правая основная -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВЫЙ КВАДРАТ -->
                            <Border Grid.Column="0"
                            Background="#2A2A2A"
                            CornerRadius="6,0,0,6"
                            Padding="5">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- X,Y -->
                                    <TextBlock Text="X, Y"
                                    Foreground="Gray"
                                    FontSize="12"
                                    HorizontalAlignment="Center"/>

                                    <!-- Координаты -->
                                    <Border Grid.Row="1"
                                    Background="#3A3A3A"
                                    CornerRadius="4"
                                    Margin="5,6,5,0"
                                    VerticalAlignment="Center">

                                        <TextBlock x:Name="OkXY"
                                           Text="0 , 0"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ПРАВАЯ ЧАСТЬ -->
                            <Grid Grid.Column="1"
                            Margin="8,6">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Название -->
                                <Border Background="#2F2F2F"
                                    CornerRadius="4"
                                    Padding="4"
                                    Margin="0,0,0,6">

                                    <TextBlock Text="''ОК''"
                                    Foreground="White"
                                    FontSize="13"
                                    HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Кнопка -->
                                <Button Name="Ok"
                                Grid.Row="1"
                                Content="НАСТРОИТЬ КООРДИНАТЫ"
                                Background="#8B0000"
                                Foreground="White"
                                FontSize="12"
                                Height="28"
                                Click="Ok_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Background="#3A3A3A"
                    CornerRadius="6"
                    Height="70"
                    Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Левая тёмная часть -->
                                <ColumnDefinition Width="70"/>
                                <!-- Правая основная -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВЫЙ КВАДРАТ -->
                            <Border Grid.Column="0"
                            Background="#2A2A2A"
                            CornerRadius="6,0,0,6"
                            Padding="5">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- X,Y -->
                                    <TextBlock Text="X, Y"
                                    Foreground="Gray"
                                    FontSize="12"
                                    HorizontalAlignment="Center"/>

                                    <!-- Координаты -->
                                    <Border Grid.Row="1"
                                    Background="#3A3A3A"
                                    CornerRadius="4"
                                    Margin="5,6,5,0"
                                    VerticalAlignment="Center">

                                        <TextBlock x:Name="ScanAreaXY"
                                           Text="0 , 0"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ПРАВАЯ ЧАСТЬ -->
                            <Grid Grid.Column="1"
                            Margin="8,6">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Название -->
                                <Border Background="#2F2F2F"
                                    CornerRadius="4"
                                    Padding="4"
                                    Margin="0,0,0,6">

                                    <TextBlock Text="''Зона сканирования''"
                                    Foreground="White"
                                    FontSize="13"
                                    HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Кнопка -->
                                <Button Name="ScanningArea"
                                Grid.Row="1"
                                Content="НАСТРОИТЬ КООРДИНАТЫ"
                                Background="#8B0000"
                                Foreground="White"
                                FontSize="12"
                                Height="28"
                                Click="ScanningArea_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Background="Transparent"/>

                </UniformGrid>
            </Border>

            <!-- ===== START / STOP ===== -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="START"
                        Width="140"
                        Height="45"
                        FontSize="16"
                        Background="#8B0000"
                        Foreground="White"
                        Margin="0,0,10,0"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>
